# Database sumber hanya untuk membaca data real dari mysml-backend.
# Jangan gunakan database sumber ini untuk menyimpan dataset/model skripsi.
SOURCE_DATABASE_URL=mysql+pymysql://user:password@localhost:3306/lms_prod_sml_03_04_26

# Database milik backend skripsi sendiri.
# Default memakai SQLite lokal agar tidak mengubah database perusahaan.
APP_DATABASE_URL=sqlite:///./storage/skripsi_backend.db

APP_HOST=127.0.0.1
APP_PORT=8000
APP_DEBUG=true
